<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <AssemblyName>SoDVR.Preload</AssemblyName>
    <RootNamespace>SoDVR.Preload</RootNamespace>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>

  <!-- GameDir is set via Directory.Build.props (not committed); see Directory.Build.props.example -->
  <PropertyGroup>
    <GameDir Condition="'$(GameDir)' == ''">C:\Program Files (x86)\Steam\steamapps\common\Shadows of Doubt</GameDir>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BepInEx.Core" Version="6.0.0-be.*" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="BepInEx.Preloader.Core">
      <HintPath>$(GameDir)\BepInEx\core\BepInEx.Preloader.Core.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <!-- Post-build: copy to BepInEx patchers.
       Skipped automatically when GameDir does not exist (e.g. CI). -->
  <Target Name="DeployPatcher" AfterTargets="Build" Condition="Exists('$(GameDir)\BepInEx')">
    <PropertyGroup>
      <PatcherDir>$(GameDir)\BepInEx\patchers\SoDVR</PatcherDir>
    </PropertyGroup>
    <MakeDir Directories="$(PatcherDir)\RuntimeDeps\Native" />
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).dll" DestinationFolder="$(PatcherDir)" />
    <Copy SourceFiles="..\RuntimeDeps\Native\openxr_loader.dll" DestinationFolder="$(PatcherDir)\RuntimeDeps\Native" />
  </Target>
</Project>
